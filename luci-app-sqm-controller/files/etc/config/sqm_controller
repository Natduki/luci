# SQM Controller Configuration
config basic_config 'basic_config'
        option enabled '0'
        option interface 'eth1'
        option download_speed '1000000'
        option upload_speed '100000'
        option queue_algorithm 'fq_codel'

config advanced_config 'advanced_config'
        option autostart '1'
        option log_level 'info'
        option log_file '/var/log/sqm_controller.log'
        option ecn 'true'

config classification 'classification'
        option enabled '1'
        option backend 'nft'
        option default_class 'other'
        option mark_gaming '0x11'
        option mark_streaming '0x12'
        option mark_bulk '0x13'
        option mark_other '0x10'

config class_rule 'gaming_udp'
        option enabled '1'
        option priority '100'
        option proto 'udp'
        option dport '3478,3659'
        option src_ip ''
        option dst_ip ''
        option sport ''
        option category 'gaming'

config class_rule 'bulk_tcp'
        option enabled '1'
        option priority '10'
        option proto 'tcp'
        option dport '80,443'
        option src_ip ''
        option dst_ip ''
        option sport ''
        option category 'bulk'

config policy 'policy'
        option enabled '1'
        option mode 'auto'
        option latency_high_ms '80'
        option loss_high_pct '2'
        option bulk_cap_pct '60'
        option gaming_floor_pct '15'
        option streaming_floor_pct '25'
        option cooldown_min '2'